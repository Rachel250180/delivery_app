 <h1>マイページ</h1>

 <%= form_with model: @user do |f| %>
    <div>
        <%= f.label :name, "名前" %>
        <%= f.text_field :name %>
    </div>

    <div>
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email %>
    </div>

    <%= f.submit "更新" %>

    <%= link_to "戻る", user_path(@user) %>

<% end %>