<h1>配達ルート管理アプリ</h1>

<p>
  配達ルートを登録・管理できます。
</p>

<h1>ルート検索アプリ</h1>

<%= form_with url: towns_path, method: :get, local: true do |f| %>
  <%= f.label :name, "町名検索" %>
  <%= f.text_field :name %>
  <%= f.submit "検索" %>
<% end %>

<div>
  <%= link_to "町一覧", towns_path %>
</div>

<div>
  <%= link_to "町登録", new_town_path %>
</div>

<% if logged_in? %>
  <div>
    <%= link_to "マイページ", user_path(current_user) %>
  </div>
<% end %>

<div>
  <% if logged_in? %>
    <%= button_to "ログアウト", logout_path, method: :delete %>
  <% else %>
    <%= button_to "ログイン", login_path, method: :get %>
  <% end %>
</div>