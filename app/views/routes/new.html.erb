<h1>ルート登録</h1>

<%= form_with model: [@town, @route] do |f| %>

  <div>
    <%= f.label :name, "ルート名" %><br>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description, "説明" %><br>
    <%= f.text_area :description %>
  </div>

  <div id="points"></div>

  <div>
    <%= f.submit "登録する" %>
  </div>

<% end %>

<div id="map" style="height: 500px;"></div>

<div style="margin-top: 10px;">
  <button type="button" onclick="undoLastPoint()">1つ戻る</button>
  <button type="button" onclick="resetPoints()">やり直す</button>
</div>

<script>
let map;
let markers = [];

// 🔥 出発点
const START_POINT = { lat: 36.27883160931458, lng: 139.3873576767888 };

function initMap() {
  map = new google.maps.Map(document.getElementById("map"), {
    zoom: 14,
    center: START_POINT,
    streetViewControl: false,
    mapTypeControl: false,
    fullscreenControl: false
  });

  // 出発点を最初に追加
  addPoint(START_POINT);

  map.addListener("click", (e) => {
    addPoint(e.latLng);
  });
}

// 📍 ポイント追加
function addPoint(latLng) {
  const lat = typeof latLng.lat === "function" ? latLng.lat() : latLng.lat;
  const lng = typeof latLng.lng === "function" ? latLng.lng() : latLng.lng;

  const index = markers.length;

  const marker = new google.maps.Marker({
    position: { lat: lat, lng: lng },
    map: map,
    // ✅ ① 出発点は「S」
    label: index === 0 ? "S" : String(index + 1),
    // ✅ ② 出発点だけ色変更（緑）
    icon: index === 0 ? "http://maps.google.com/mapfiles/ms/icons/green-dot.png" : null
  });

  markers.push(marker);

  const container = document.getElementById("points");

  container.insertAdjacentHTML("beforeend", `
    <div class="point">
      <input type="hidden" name="route[route_points_attributes][${index}][latitude]" value="${lat}">
      <input type="hidden" name="route[route_points_attributes][${index}][longitude]" value="${lng}">
      <input type="hidden" name="route[route_points_attributes][${index}][position]" value="${index + 1}">
    </div>
  `);

  renumberMarkers();
}

// 🔢 番号振り直し（ここも対応）
function renumberMarkers() {
  markers.forEach((marker, i) => {
    marker.setLabel(i === 0 ? "S" : String(i + 1));
  });
}

// 🔙 戻る（出発点は消せない）
function undoLastPoint() {
  if (markers.length <= 1) return;

  const marker = markers.pop();
  marker.setMap(null);

  const container = document.getElementById("points");
  const lastPoint = container.lastElementChild;

  if (lastPoint) lastPoint.remove();

  renumberMarkers();
}

// 🔄 リセット（出発点は残す）
function resetPoints() {
  while (markers.length > 1) {
    const marker = markers.pop();
    marker.setMap(null);
  }

  const container = document.getElementById("points");

  while (container.children.length > 1) {
    container.lastElementChild.remove();
  }

  renumberMarkers();
}
</script>

<script async
  src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.application.credentials.google_maps_api_key %>&callback=initMap">
