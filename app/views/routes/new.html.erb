<h1>ルート登録</h1>

<%= form_with model: [@town, @route] do |f| %>

  <div>
    <%= f.label :name, "ルート名" %><br>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description, "説明" %><br>
    <%= f.text_area :description %>
  </div>

  <div id="points"></div>

  <div>
    <%= f.submit "登録する" %>
  </div>

<% end %>

<div id="map" style="height: 500px;"></div>

<div style="margin-top: 10px;">
  <button type="button" onclick="undoLastPoint()">1つ戻る</button>
  <button type="button" onclick="resetPoints()">やり直す</button>
</div>

<%= javascript_include_tag "map_route" %>

<script
src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.application.credentials.google_maps_api_key %>&callback=initMapNew"
defer>
</script>
