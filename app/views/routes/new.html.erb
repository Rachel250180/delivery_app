<h1>ルート登録</h1>

<%= form_with model: [@town, @route] do |f| %>
  <div>
    <%= f.label :name, "ルート名" %><br>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description, "説明" %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.submit "登録する" %>
  </div>
<% end %>

<%= link_to "一覧へ戻る", town_path(@town) %>