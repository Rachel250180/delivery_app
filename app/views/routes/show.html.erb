<h1><%= @route.name %></h1>

<p><%= @route.description %></p>

<% points = @route.route_points.order(:position) %>

<% if points.any? %>
  <% origin = "#{points.first.latitude},#{points.first.longitude}" %>
  <% destination = "#{points.last.latitude},#{points.last.longitude}" %>

  <% waypoints = points[1...-1].map { |p| "#{p.latitude},#{p.longitude}" }.join("|") %>

  <% url = "https://www.google.com/maps/dir/?api=1" %>
  <% url += "&origin=#{origin}" %>
  <% url += "&destination=#{destination}" %>
  <% url += "&waypoints=#{waypoints}" if waypoints.present? %>
  <% url += "&travelmode=driving" %>

  <a href="<%= url %>" target="_blank">
    Googleマップでルートを見る
  </a>
<% end %>

<div id="map" style="height: 500px;"></div>

<script>
const points = <%= raw points.to_json %>;

let directionsService;
let directionsRenderer;

  function initMap() {
    const otaten = { lat: 36.27883160931458, lng: 139.3873576767888 };

    const map = new google.maps.Map(document.getElementById("map"), {
      zoom: 14,
      center: otaten,
      streetViewControl: false,
      mapTypeControl: false,
    });
    directionsService = new google.maps.DirectionsService();
    directionsRenderer = new google.maps.DirectionsRenderer();

    directionsRenderer.setMap(map);

    drawingRoute();
  }

  function drawingRoute() {
    const coordinates = points.map((point) => {
      return {
        lat: point.latitude, 
        lng: point.longitude
        };
    });
  
    directionsService.route({
      origin: coordinates[0],
      destination: coordinates[coordinates.length - 1],
      waypoints: coordinates.slice( 1, -1).map((coordinate) =>{
        return {location: coordinate,
                stopover: true
                }
      }),
      travelMode: google.maps.TravelMode.DRIVING
    }, (result, status) => {
    if (status === "OK") {
      directionsRenderer.setDirections(result);
      }
    });
  } 
</script>

<script async
  src="https://maps.googleapis.com/maps/api/js?key=<%= Rails.application.credentials.google_maps_api_key %>&callback=initMap">
</script>

<%= link_to "編集", edit_town_route_path(@town, @route) %>

<%= link_to "一覧へ戻る", town_path(@town) %>
