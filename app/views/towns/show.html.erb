<div class="towns-container">
  <h1><i class="fa-solid fa-flag"></i><%= @town.name %>のルート一覧</h1>

  <ul class="index">
    <% @routes.each do |route| %>
      <li><%= link_to route.name, town_route_path(@town, route)  %></li>
    <% end %>
  </ul>


  <%= link_to "ルートを登録", new_town_route_path(@town) %>
  <%= link_to "町を編集", edit_town_path(@town) %>
  <%= link_to "戻る", towns_path %>

</div>