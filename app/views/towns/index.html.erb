<div>
  <section class="search-town">
    <h2>町を検索する</h2>

      <%= form_with url: towns_path, method: :get, local: true, class: "search-form" do |f| %>
        <%= f.text_field :name, placeholder: "町名を入力してください" %>
        <%= f.submit "検索", class: "search-btn" %>
      <% end %>
  </section>

  <section class="towns-index">
    <h1>町一覧</h1>

    <ul class="index">
      <% @towns.each do |town| %>
        <li>
          <%= link_to town.name, town_path(town) %>
        </li>
      <% end %>
    </ul>

  </section>
</div>











<div>
  <%= link_to "町登録", new_town_url%>
</div>

<%= link_to "戻る", root_path %>
